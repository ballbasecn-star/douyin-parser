# Douyin Parser 环境变量模板
#
# 使用方式：
# 1. 复制当前文件为项目根目录下的 .env
# 2. 按需填写下面的变量
#
# 说明：
# - CLI 入口 `python main.py ...` 会自动加载项目根目录的 .env
# - Docker / compose 部署请优先使用各自目录下的 .env.example
# - Web 界面中的“设置”面板也可以在运行时写入部分 API Key

# -------------------------------------------------------------------
# 云端转录与 AI 拆解
# -------------------------------------------------------------------

# SiliconFlow API Key
# 作用：
# - SiliconFlow 云端语音转录
# - AI 爆款文案拆解
# 获取地址：https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=

# Groq API Key
# 作用：
# - Groq 云端语音转录
# 获取地址：https://console.groq.com/keys
GROQ_API_KEY=

# -------------------------------------------------------------------
# 本地数据与数据库
# -------------------------------------------------------------------

# Cookie 存储目录
# 默认值：项目根目录下的 cookie_data
# 本地开发通常可以保持默认；Docker 中建议挂载到持久化目录
# COOKIE_DIR=./cookie_data

# 数据库连接串
# dev 环境建议直接使用独立 PostgreSQL 数据库。
# 如果未配置 DATABASE_URL，当前代码仍会回退到 sqlite:///data/app_dev.sqlite3，
# 但该回退只建议用于临时验证或测试，不应作为正式开发环境标准。
#
# PostgreSQL 示例（推荐作为 dev 标准）：
# DATABASE_URL=postgresql+psycopg://douyin_parser:your_password@127.0.0.1:5432/douyin_parser_dev
#
# SQLite 示例（仅建议用于临时调试或测试）：
# DATABASE_URL=sqlite:///data/app_dev.sqlite3

# -------------------------------------------------------------------
# Web 服务端口
# -------------------------------------------------------------------

# Web 页面/API 端口
# Docker 镜像默认值：8080
PORT=8080

# Cookie Webhook 端口
# Chrome Cookie Sniffer 扩展回传 Cookie 时会用到
# Docker 镜像默认值：5555
WEBHOOK_PORT=5555

# -------------------------------------------------------------------
# 可选：给 scripts/douyin_parser_client.py 使用
# -------------------------------------------------------------------

# 远端服务地址
# 默认值：http://127.0.0.1:8080
DOUYIN_PARSER_BASE_URL=http://127.0.0.1:8080

# 客户端超时时间（秒）
# 默认值：600
DOUYIN_PARSER_TIMEOUT=600

# 可选 Bearer Token
# 当前服务端默认未启用鉴权；后续如果启用，可在这里配置
# DOUYIN_PARSER_TOKEN=
