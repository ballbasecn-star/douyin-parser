# Douyin Parser 生产环境变量模板
#
# 使用方式：
# 1. 复制当前文件为 deploy/douyin-parser/.env
# 2. 填写真实密钥与数据库连接串
# 3. 复制 release.env.example 为 release.env
# 4. compose 通过：
#    - .env 传入应用运行配置
#    - release.env 传入当前部署镜像与发布版本

# -------------------------------------------------------------------
# 云端能力
# -------------------------------------------------------------------

# SiliconFlow API Key
# 用于：
# - SiliconFlow 云端转录
# - AI 爆款文案拆解
SILICONFLOW_API_KEY=

# Groq API Key
# 用于：
# - Groq 云端转录
GROQ_API_KEY=

# -------------------------------------------------------------------
# 持久化与数据库
# -------------------------------------------------------------------

# Cookie 数据在容器内的挂载目录
# compose 已默认把 ./data/cookie_data 挂到这里
COOKIE_DIR=/app/cookie_data

# 生产环境建议使用 PostgreSQL
# 示例：
# DATABASE_URL=postgresql+psycopg://douyin_parser:your_password@postgres:5432/douyin_parser_prod
DATABASE_URL=

# -------------------------------------------------------------------
# 服务端口
# -------------------------------------------------------------------

# Web 页面 / API 端口
PORT=8080

# Cookie Webhook 端口
WEBHOOK_PORT=5555
