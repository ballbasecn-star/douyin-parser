# Docker Compose 部署变量模板
#
# 使用方式：
# 1. 复制当前文件为 deploy/douyin-parser/release.env
# 2. 在每次发布时，由部署脚本自动更新其中的镜像和发布版本
# 3. docker compose 使用 --env-file release.env 读取该文件

# 当前要部署的镜像
DOUYIN_PARSER_IMAGE=ballbase/douyin-parser:v1.0.0-20260321-abcdef1

# 当前发布版本号
# 建议格式：
# v<应用版本>-<时间戳>-<git短提交>
APP_RELEASE_VERSION=v1.0.0-20260321-abcdef1
